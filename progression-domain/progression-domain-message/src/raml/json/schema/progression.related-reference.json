{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/progression/query/related-reference.json",
  "type": "object",
  "properties": {
    "relatedReference": {
      "type": "string"
    },
    "relatedReferenceId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "prosecutionCaseId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "isCivil": {
      "description": "True if the related case is a civil case, false if criminal, absent if the related case cannot be resolved",
      "type": "boolean"
    }
  },
  "required": [
    "relatedReference",
    "relatedReferenceId",
    "prosecutionCaseId"
  ],
  "additionalProperties": false
}

