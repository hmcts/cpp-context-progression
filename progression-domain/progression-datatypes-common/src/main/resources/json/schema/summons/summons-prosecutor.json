{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/core/courts/summons/summons-prosecutor.json",
  "description": "The details for of a defendant rendered in a summons document",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "address": {
      "$ref": "http://justice.gov.uk/core/courts/summons/summons-address.json"
    },
    "emailAddress": {
      "format": "email",
      "type": "string"
    }
  },
  "required": [
    "name",
    "address"
  ],
  "additionalProperties": false
}